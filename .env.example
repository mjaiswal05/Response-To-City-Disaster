# Example Environment Configuration
# Copy this file to .env.local and configure for your local development setup

# ============================================
# LOCAL DEVELOPMENT SETUP
# ============================================
# Uncomment these lines to test with local IAM service:
# VITE_IAM_SERVICE_URL=http://localhost:8081
# VITE_API_BASE_URL=http://localhost:8081

# VITE_LOGOUT_REDIRECT_URI=http://localhost:5173

# ============================================
# TOMTOM MAPS
# ============================================
# VITE_TOMTOM_API_KEY=your_tomtom_api_key_here

# ============================================
# PRODUCTION/GKE DEPLOYMENT
# ============================================
# Leave all values commented out to use production defaults
# The vite.config.ts will default to https://beacon-tcd.tech
